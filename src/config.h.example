// ===========================================================================
// config.h.example  —  YOUR PERSONAL SETTINGS TEMPLATE
// ---------------------------------------------------------------------------
// HOW TO USE THIS FILE:
//   1. Make a COPY of this file in the same folder and name the copy
//      "config.h" (drop the ".example").
//   2. Fill in your WiFi name/password and your MQTT (Home Assistant) details.
//   3. Save. That's it — the rest of the program reads its settings from here.
//
// WHY A COPY?  The copy ("config.h") contains your WiFi and MQTT passwords, so
// it is deliberately kept OUT of the public GitHub repository (see .gitignore).
// This template, with no real passwords in it, is the only version that gets
// shared publicly.
// ===========================================================================

#ifndef CONFIG_H
#define CONFIG_H

// ---------------------------------------------------------------------------
// 1. WiFi — how the board gets on your home network
// ---------------------------------------------------------------------------
// The board needs WiFi so it can send weather readings to Home Assistant.
#define WIFI_SSID      "YourWiFiName"        // the name of your WiFi network
#define WIFI_PASSWORD  "YourWiFiPassword"    // the WiFi password

// ---------------------------------------------------------------------------
// 2. MQTT — the "post office" that Home Assistant listens to
// ---------------------------------------------------------------------------
// MQTT is a simple messaging system. The board publishes ("posts") weather
// readings, and Home Assistant subscribes ("reads") them. The broker is the
// post office in the middle. If you use Home Assistant OS with the Mosquitto
// add-on, the broker IP is usually your Home Assistant's IP address.
#define MQTT_HOST      "192.168.73.XXX"      // IP address of your MQTT broker (Mosquitto)
#define MQTT_PORT      1883                  // standard MQTT port; leave as-is unless you changed it
#define MQTT_USER      "mqtt_username"       // the MQTT login you created in Home Assistant
#define MQTT_PASSWORD  "mqtt_password"       // the matching MQTT password

// A short name for THIS device on the network. It shows up in Home Assistant
// and is used to build the topic names. Stick to letters, numbers, and
// underscores (no spaces).
#define DEVICE_ID      "davis_iss"
#define DEVICE_NAME    "Davis Weather Station"   // friendly name shown in Home Assistant

// ---------------------------------------------------------------------------
// 3. Your Davis station's transmitter ID
// ---------------------------------------------------------------------------
// Every Davis sensor suite is set to a transmitter ID from 1 to 8 (you pick it
// with the dip switches inside the ISS; the console calls it "Station ID").
// IMPORTANT: subtract 1 here. If your console shows Station 1, put 0 below.
// This ID controls the exact timing between transmissions, so it must match.
#define STATION_ID     0     // console "Station 1" => 0, "Station 2" => 1, etc.

// ---------------------------------------------------------------------------
// 4. Units — how readings are shown and published
// ---------------------------------------------------------------------------
// Set to 1 for US/Imperial units (Fahrenheit, mph, inches).
// Set to 0 for Metric units (Celsius, km/h, millimeters).
#define USE_IMPERIAL_UNITS  1

// ---------------------------------------------------------------------------
// 4b. Use the onboard OLED screen?
// ---------------------------------------------------------------------------
// Set to 1 to show readings on the board's little screen, or 0 to run without
// it ("headless"). Everything still works headless — readings just go to Home
// Assistant and the serial log instead of the screen.
//
// SET THIS TO 0 IF: the board reboots over and over and the last line you see
// is "[setup] 2/4 starting display". That means the screen isn't responding on
// the expected pins, and trying to talk to it stalls the whole board. Running
// headless avoids that entirely.
#define ENABLE_OLED  1

// ---------------------------------------------------------------------------
// 5. Which LoRa radio chip is on your board?
// ---------------------------------------------------------------------------
// The LilyGO T3 v1.6.1 comes with one of two radio chips. They look similar but
// need slightly different setup, so you must tell the code which one you have.
//
// HOW TO FIND OUT: look at the small metal can (the radio module) on the board.
// It's printed with the chip name — either "SX1276" or "SX1262".
//
// Leave exactly ONE of the two lines below uncommented (no leading "//").
// If you're not sure, start with SX1276 (the most common). If the radio fails
// to start when you run it, switch to SX1262 and re-flash.
#define RADIO_CHIP_SX1276
// #define RADIO_CHIP_SX1262

// ---------------------------------------------------------------------------
// 6. Hardware pin map — how the radio and screen are wired to the ESP32
// ---------------------------------------------------------------------------
// These are the factory wiring connections on the LilyGO T3 v1.6.1. You should
// NOT need to change these unless you have a different board revision. If the
// radio never starts up (see the serial monitor), double-check these against
// your board's documentation — see docs/01-hardware-and-wiring.md.
//
// Both radio versions (SX1276 and SX1262) use the same SPI wiring; they differ
// only in one control pin: the SX1276 uses "DIO0" and the SX1262 uses "BUSY".
// We define both here, and the code uses whichever one matches the radio chip
// you selected above.

// -- LoRa radio chip (connected over a bus called "SPI") --
#define PIN_LORA_SCK    5    // SPI clock
#define PIN_LORA_MISO   19   // SPI data: radio -> ESP32
#define PIN_LORA_MOSI   27   // SPI data: ESP32 -> radio
#define PIN_LORA_CS     18   // "chip select" — tells the radio we're talking to it
#define PIN_LORA_RST    23   // reset line for the radio
#define PIN_LORA_DIO0   26   // SX1276 only: "packet arrived" interrupt pin
#define PIN_LORA_DIO1   33   // interrupt pin (used by both chips)
#define PIN_LORA_BUSY   32   // SX1262 only: "busy" line the chip raises while working

// -- SSD1306 OLED screen (connected over a bus called "I2C") --
#define PIN_OLED_SDA    21   // I2C data line
#define PIN_OLED_SCL    22   // I2C clock line
// NOTE: the screen's reset is wired to GPIO16, but on this module GPIO16 is also
// tied to internal memory (PSRAM) and driving it FREEZES the board. So we leave
// it completely alone — the screen resets fine on power-up. (PIN unused below,
// kept for reference only. Do NOT drive it.)
#define PIN_OLED_RST    16

// ---------------------------------------------------------------------------
// 7. Severe-weather ALERT thresholds (SkyWarn-style)
// ---------------------------------------------------------------------------
// When a reading crosses one of these limits, the board raises a visible ALERT:
// it flashes a banner on the screen and blinks the blue LED, and it turns on a
// "Weather Alert" switch in Home Assistant that you can build automations on.
//
// The defaults below come from the NWS PHOENIX SkyWarn spotter reporting
// criteria (https://www.weather.gov/psr/skywarn.html). IMPORTANT: these criteria
// are LOCATION-DEPENDENT — every NWS office sets its own. If you are not in the
// Phoenix area, look up your local office's spotter page and change these.
//
// Set any threshold to 0 to turn that particular check off.

#define ALARM_ENABLE  1     // 1 = turn the alert feature on, 0 = off entirely

// HEAVY RAIN. NWS Phoenix asks spotters to report 0.50 inch or more of rain in
// 30 minutes or less. The firmware keeps a rolling 30-minute rain total and
// alerts when it reaches this many inches.
#define ALARM_RAIN_30MIN_INCHES   0.50

// DAMAGING WIND GUST (mph). The Phoenix page lists no specific wind number, so
// this 40 mph default is the common SkyWarn "go ahead and report it" level.
// (A severe thunderstorm warning is issued at 58 mph.) Adjust to taste.
#define ALARM_WIND_GUST_MPH       40

// HIGH SUSTAINED WIND (mph). Off by default (0). In dust-storm country you might
// set this around 35-40 to catch the strong steady winds that kick up haboobs.
#define ALARM_WIND_SUSTAINED_MPH  0

// After an alert trips, keep showing it for at least this many seconds even once
// the reading falls back below the limit — so a single brief gust still gets
// noticed instead of flickering away instantly.
#define ALARM_HOLD_SECONDS        120

// The onboard LED to blink during an alert. On the LilyGO T3 this is usually
// GPIO25. Set ALARM_LED_ENABLE to 0 if your board has no usable LED there (the
// on-screen alert still works), or change the pin number to match your board.
#define ALARM_LED_ENABLE  1
#define PIN_ALERT_LED     25

// ---------------------------------------------------------------------------
// 8. Onboard web dashboard (the board serves its own chart page)
// ---------------------------------------------------------------------------
// When this is on, the board runs a tiny website you can open in any browser on
// your network. It shows the current conditions and graphs of the weather since
// the board last started up. The history lives in the board's memory, so it
// resets when the board reboots and only goes back as far as the settings below.

#define WEB_ENABLE     1            // 1 = run the web dashboard, 0 = off
#define WEB_HOSTNAME   "davis"      // reach it at http://davis.local (and the IP)

// How often to record a point for the history graphs, and how many points to
// keep. 120 seconds x 720 points = the last 24 hours. More/longer points use
// more memory (each point is tiny — ~14 bytes).
#define WEB_SAMPLE_SECONDS  120
#define WEB_HISTORY_POINTS  720

// Your name / callsign / project link, shown as a tagline at the top and bottom
// of the web page. Leave the callsign as "" if you don't have one.
#define WEB_OWNER     "Your Name"
#define WEB_CALLSIGN  ""
#define WEB_REPO_URL  "https://github.com/openincident/davisreport"

// ---------------------------------------------------------------------------
// 9. Optional tuning knobs (safe to leave at defaults)
// ---------------------------------------------------------------------------
// How often (in seconds) to re-send EVERY reading to Home Assistant even if the
// value hasn't changed. This keeps Home Assistant from marking sensors as
// "unavailable" during calm weather. 300 = every 5 minutes.
#define MQTT_REPUBLISH_SECONDS  300

#endif // CONFIG_H
